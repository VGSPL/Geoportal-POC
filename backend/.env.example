# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── PostgreSQL (RDS) ──────────────────────────────────────────────────────────
# Format: postgresql://username:password@rds-endpoint:5432/dbname
DATABASE_URL=postgresql://geoportal_user:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/geoportal_db

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# On EC2 with an IAM role, AWS credentials are picked up automatically.
# You only need to set the bucket name and its public base URL.
S3_BUCKET_NAME=geoportal-uploads-xxxxxxxx
S3_BASE_URL=https://geoportal-uploads-xxxxxxxx.s3.ap-south-1.amazonaws.com
AWS_REGION=ap-south-1
